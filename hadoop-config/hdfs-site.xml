<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
  <!-- Replication factor (1 for dev, 3 for prod cluster) -->
  <property>
    <n>dfs.replication</n>
    <value>1</value>
  </property>

  <!-- NameNode data directory -->
  <property>
    <n>dfs.namenode.name.dir</n>
    <value>/opt/hadoop/data/nameNode</value>
  </property>

  <!-- DataNode data directory -->
  <property>
    <n>dfs.datanode.data.dir</n>
    <value>/opt/hadoop/data/dataNode</value>
  </property>

  <!-- Enable WebHDFS -->
  <property>
    <n>dfs.webhdfs.enabled</n>
    <value>true</value>
  </property>

  <!-- NameNode Web UI port -->
  <property>
    <n>dfs.namenode.http-address</n>
    <value>0.0.0.0:9870</value>
  </property>

  <!-- DataNode Web UI port -->
  <property>
    <n>dfs.datanode.http.address</n>
    <value>0.0.0.0:9864</value>
  </property>

  <!-- Allow remote hosts to access WebHDFS -->
  <property>
    <n>dfs.namenode.datanode.registration.ip-hostname-check</n>
    <value>false</value>
  </property>

  <!-- Block size (128 MB default) -->
  <property>
    <n>dfs.blocksize</n>
    <value>134217728</value>
  </property>

  <!-- Permissions (relaxed for dev) -->
  <property>
    <n>dfs.permissions.enabled</n>
    <value>false</value>
  </property>
</configuration>