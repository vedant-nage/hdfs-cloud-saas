# Server Configuration
PORT=3000
NODE_ENV=production

# HDFS Configuration
HDFS_HOST=localhost
HDFS_PORT=9870
HDFS_USER=hadoop
HDFS_BASE_PATH=/cloud-storage

# Encryption Configuration
AES_SECRET_KEY=your-super-secret-key-change-this-in-production-32chars
AES_IV_LENGTH=16

# File Configuration
MAX_FILE_SIZE_MB=500
CHUNK_SIZE_MB=4

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
